{
  "name": "tea-shelf",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "corepack pnpm --filter web dev",
    "build": "corepack pnpm -r build",
    "lint": "corepack pnpm -r lint",
    "preview": "corepack pnpm --filter web preview",
    "release:smoke": "corepack pnpm --filter web release:smoke",
    "test": "corepack pnpm -r test",
    "test:e2e": "corepack pnpm --filter web test:e2e",
    "typecheck": "corepack pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
